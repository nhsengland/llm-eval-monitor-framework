{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://nhsengland.github.io/...",
    "title": "LLM Evaluation and Monitoring Framework Dimensions",
    "description": "Dimensions for the LLM Evaluation and Monitoring Framework",
    "type": "object",
    "properties": {
        "terms": {
            "description": "The list of dimensions of the LLM Evaluation and Monitoring Framework",
            "type": "array",
            "items": {
                "description": "A dimension of the LLM Evaluation and Monitoring Framework",
                "type": "object",
                "properties": {
                    "metaGroup": {
                        "description": "The higher level group the dimension falls under",
                        "type": "string",
                        "minLength": 1
                    },
                    "metaDimension": {
                        "description": "The dimension of the LLM Evaluation and Monitoring Framework",
                        "type": "string"
                    },
                    "considerationsSetup": {
                        "description": "Considerations which need to be addressed at the setup of LLM evaluation and monitoring",
                        "type": "string",
                        "minLength": 2
                    },
                    "monitoringAction": {
                        "description": "Action to be taken during monitoring",
                        "type": "string",
                        "minLength": 2
                    },
                    "monitoringRationale": {
                        "description": "Rationale for monitoring the dimension",
                        "type": "string",
                        "minLength": 2
                    },
                    "monitoringFrequency": {
                        "description": "How often the monitoring should occur",
                        "type": "string",
                        "minLength": 2
                    },
                    "monitoringUpdate": {
                        "description": "Conditions under which the model should be updated",
                        "type": "string",
                        "minLength": 2
                    },
                    "monitoringRetire": {
                        "description": "Conditions under which the model should be retired",
                        "type": "string",
                        "minLength": 2
                    },
                    "updateretireUpdate": {
                        "description": "Updating procedures",
                        "type": "string",
                        "minLength": 2
                    },
                    "updateretireRetire": {
                        "description": "Retirement procedures",
                        "type": "string",
                        "minLength": 2
                    },
                    "termCode": {
                        "description": "Short form identifier for the term, used in related terms and for URL bookmarking",
                        "type": "string",
                        "$ref": "#/definitions/termCode"
                    },
                    "related": {
                        "description": "A list of related terms",
                        "type": "array",
                        "items": {
                            "description": "Term codes for related terms",
                            "type": "string",
                            "$ref": "#/definitions/termCode"
                        },
                        "uniqueItems": true
                    }
                },
                "required": [
                    "metaGroup",
                    "metaDimension",
                    "considerationsSetup",
                    "termCode"
                ]
            },
            "uniqueItems": true
        }
    },
    "required": [
        "terms"
    ],
    "additionalProperties": false,
    "definitions": {
        "termCode": {
            "description": "Unique short form identifier for a specific dimension",
            "type": "string",
            "minLength": 1
        }
    }
}